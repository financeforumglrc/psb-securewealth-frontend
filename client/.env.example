# Supabase Configuration
# Get these from your Supabase Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For SMS OTP (Twilio or MSG91)
# VITE_SMS_PROVIDER=twilio

# SecureWealth Protection API (FastAPI microservice)
# Local dev: http://localhost:8000
# Deployed example: https://your-protection-service.onrender.com
VITE_PROTECTION_API_URL=http://localhost:8000

# PSB Banking Node backend
VITE_BACKEND_URL=https://psb-banking-backend.onrender.com/api/v1

# ═══════════════════════════════════════════════════════════════
# Wealth Twin AI — Default provider keys (demo builds)
# ═══════════════════════════════════════════════════════════════
# You can inject all provider keys at build time. They will be seeded into
# the browser's localStorage AI Provider Hub on first load.
#
# Priority order applied automatically:
#   Primary/free route: Gemini → Groq → OpenRouter → Mistral → Cohere → Hugging Face
#   Premium fallback:   OpenAI → Anthropic → Grok → NVIDIA → DeepSeek
#
# DeepSeek is treated as a paid premium fallback — keep it last if you want
# free/cheap providers to be tried first.
#
# SECURITY NOTE: These keys will be baked into the production JS bundle.
# For a real production app, proxy calls through your backend instead.
# Put actual secrets in .env.production.local (gitignored) so they are not committed.
# ═══════════════════════════════════════════════════════════════
VITE_DEFAULT_GEMINI_KEY=
VITE_DEFAULT_GROQ_KEY=
VITE_DEFAULT_OPENROUTER_KEY=
VITE_DEFAULT_MISTRAL_KEY=
VITE_DEFAULT_COHERE_KEY=
VITE_DEFAULT_HUGGINGFACE_KEY=
VITE_DEFAULT_OPENAI_KEY=
VITE_DEFAULT_ANTHROPIC_KEY=
VITE_DEFAULT_GROK_KEY=
VITE_DEFAULT_NVIDIA_KEY=
VITE_DEFAULT_DEEPSEEK_KEY=
