# Database adapter — 'sqlite' for hackathon/demo, 'postgres' for production
DB_TYPE=sqlite
DATABASE_URL=

# Demo mode pre-seeds a fictional user (demo-001) for judge presentations
DEMO_MODE=false

# Render keep-alive targets
BACKEND_URL=https://psb-securewealth-backend.onrender.com
FRONTEND_URL=https://psb-securewealth-frontend.onrender.com

# Server
PORT=5000
NODE_ENV=development

# AI provider keys (at least one recommended for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
ALPHA_VANTAGE_KEY=

# Admin credentials (required in production; defaults allowed only in development/test)
ADMIN_ID=admin
ADMIN_PASSWORD=1234

# Development-only auth bypass; NEVER enable in production
ALLOW_DEV_AUTH_BYPASS=false

# JWT
JWT_SECRET=change-me-in-production
# Code reads JWT_EXPIRE / JWT_REFRESH_EXPIRE (fallback to values below)
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
